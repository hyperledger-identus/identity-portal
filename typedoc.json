{
  "$schema": "https://typedoc.org/schema.json",
  "name": "Identity Portal API",
  "entryPoints": ["src"],
  "entryPointStrategy": "expand",
  "tsconfig": "tsconfig.json",
  "out": "docs/api",
  "exclude": [
    "**/node_modules/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/cloud-agent/client.ts",
    "**/cloud-agent/spec.ts"
  ],
  "excludeExternals": true,
  "skipErrorChecking": true,
  "readme": "none"
}
