# ──────────────────────────────────────────────────────────────────────────────
# Identity Portal environment configuration
#
# Copy to `.env` and adjust. Every value has a local-dev default baked into the
# app and docker compose, so an empty `.env` works for `npm run local:up` out of
# the box. This same file feeds both the portal server (via dotenv) and docker
# compose variable interpolation.
# ──────────────────────────────────────────────────────────────────────────────

# ── Portal server ─────────────────────────────────────────────────────────────
# PORT=3000
# NODE_ENV=development
# AGENT_MODE=local

# ── Keycloak / OIDC (BFF auth gateway) ─────────────────────────────────────────
# Issuer used by the portal server for OIDC discovery. Must be reachable from the
# server AND match the browser-facing Keycloak origin (so token `iss` validates).
# KEYCLOAK_ISSUER_URL=http://localhost:9980/realms/atala-demo
# KEYCLOAK_PUBLIC_URL=http://localhost:9980
# OIDC_CLIENT_ID=identity-portal
# OIDC_CLIENT_SECRET=identity-portal-ui-secret
# OIDC_BASE_URL=http://localhost:3000
# OIDC_REDIRECT_URI=http://localhost:3000/auth/callback

# Secret used to encrypt the session cookie. MUST be at least 32 characters.
# Generate one with: openssl rand -hex 32
# SESSION_SECRET=
# SESSION_COOKIE_NAME=portal_session
# SESSION_TTL=28800

# Backend rate limiting for the native (password) login endpoint. This is layered
# on top of Keycloak's own brute-force protection.
# LOGIN_RATE_LIMIT_WINDOW_MS=900000
# LOGIN_RATE_LIMIT_MAX=10

# Consumed by the Keycloak init container to create the portal client. Keep in
# sync with OIDC_CLIENT_SECRET above.
# PORTAL_CLIENT_SECRET=identity-portal-ui-secret
# PORTAL_BASE_URL=http://localhost:3000

# ── Social login (optional) ────────────────────────────────────────────────────
# When an id+secret pair is set, `local:up` / `cloud-agent:up` provisions the
# matching Keycloak identity provider and the portal shows its sign-in button.
#
# Create the OAuth app in each provider's console and set its authorized
# redirect / callback URL to Keycloak's broker endpoint:
#   Google: http://localhost:9980/realms/atala-demo/broker/google/endpoint
#   GitHub: http://localhost:9980/realms/atala-demo/broker/github/endpoint
#
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Force the social buttons on/off independent of the credentials above
# (default: enabled when the matching credentials are present).
# AUTH_GOOGLE_ENABLED=true
# AUTH_GITHUB_ENABLED=true
