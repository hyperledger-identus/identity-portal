{
  "name": "identity-portal",
  "version": "0.0.0",
  "private": true,
  "description": "Hyperledger Identus Identity Portal",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "npm@11.9.0",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "npm run build:ui && npm run build:server",
    "build:ui": "vite build",
    "build:server": "node esbuild.config.mjs",
    "start": "node --import ./dist/require-shim.js dist/main.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "docs:api": "typedoc",
    "local:up": "docker compose -f docker.local.compose.yml up -d",
    "local:down": "docker compose -f docker.local.compose.yml down --remove-orphans",
    "local:logs": "docker compose -f docker.local.compose.yml logs -f",
    "cloud-agent:up": "docker compose -f docker.cloud.compose.yml up -d",
    "cloud-agent:down": "docker compose -f docker.cloud.compose.yml down --remove-orphans",
    "cloud-agent:logs": "docker compose -f docker.cloud.compose.yml logs -f"
  },
  "dependencies": {
    "@hyperledger/identus-sdk": "^8.1.0",
    "@meshsdk/core": "^1.9.0",
    "@meshsdk/react": "^2.0.0-beta.2",
    "@reduxjs/toolkit": "^2.12.0",
    "@trust0/ridb-mongodb": "^0.1.0",
    "@types/elliptic": "^6.4.18",
    "@zodyac/zod-mongoose": "^4.2.2",
    "buffer": "^6.0.3",
    "bullmq": "^5.79.2",
    "core-js": "^3.47.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "elliptic": "^6.6.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "ioredis": "^5.11.1",
    "iron-session": "^8.0.4",
    "jsdom": "^24.1.3",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^7.4.0",
    "mongoose": "^8.2.3",
    "multer": "^1.4.5-lts.2",
    "openid-client": "^6.8.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-redux": "^9.2.0",
    "swagger-ui-express": "^5.0.1",
    "tslib": "^2.3.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.18.0",
    "@types/react": "^18.3.25",
    "@types/react-dom": "^18.3.7",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.27.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "tailwindcss": "^3.4.18",
    "tsx": "^4.22.4",
    "typedoc": "^0.28.14",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.45.0",
    "vite": "^8.0.16",
    "vitest": "^4.0.15"
  }
}
