{
  "name": "identity-portal",
  "version": "0.0.0",
  "private": true,
  "description": "Hyperledger Identus Identity Portal",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "npm@11.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "nx serve portal",
    "start": "node dist/apps/portal/main.js",
    "build": "nx run-many --target=build",
    "build:portal": "nx build portal",
    "serve:portal": "nx serve portal",
    "lint": "nx run-many --target=lint",
    "typecheck": "nx run-many --target=typecheck",
    "test": "nx run-many --target=test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "docs:api": "typedoc",
    "local:up": "docker compose -f docker.local.compose.yml up -d",
    "local:down": "docker compose -f docker.local.compose.yml down --remove-orphans",
    "local:logs": "docker compose -f docker.local.compose.yml logs -f",
    "cloud-agent:up": "docker compose -f docker.cloud.compose.yml up -d",
    "cloud-agent:down": "docker compose -f docker.cloud.compose.yml down --remove-orphans",
    "cloud-agent:logs": "docker compose -f docker.cloud.compose.yml logs -f"
  },
  "dependencies": {
    "@hyperledger/identus-sdk": "^8.0.0",
    "@meshsdk/core": "^1.9.0",
    "@meshsdk/react": "^2.0.0-beta.2",
    "@reduxjs/toolkit": "^2.12.0",
    "@trust0/ridb-mongodb": "^0.0.14",
    "@types/elliptic": "^6.4.18",
    "buffer": "^6.0.3",
    "core-js": "^3.47.0",
    "cors": "^2.8.6",
    "elliptic": "^6.6.1",
    "express": "^5.2.1",
    "jsdom": "^24.1.3",
    "mongodb": "^7.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-redux": "^9.2.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@nx/esbuild": "22.7.5",
    "@nx/eslint": "22.7.5",
    "@nx/eslint-plugin": "22.7.5",
    "@nx/js": "22.7.5",
    "@nx/node": "^22.7.5",
    "@nx/vite": "^22.4.4",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.18.0",
    "@types/react": "^18.3.25",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.27.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "nx": "^22.4.4",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "tailwindcss": "^3.4.18",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typedoc": "^0.28.14",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.45.0",
    "vite": "^8.0.16",
    "vitest": "^4.0.15"
  }
}
