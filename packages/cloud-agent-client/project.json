{
  "name": "cloud-agent-client",
  "projectType": "library",
  "sourceRoot": "packages/cloud-agent-client/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "tsc -p tsconfig.json --outDir dist",
        "cwd": "packages/cloud-agent-client"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit -p tsconfig.json",
        "cwd": "packages/cloud-agent-client"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint .",
        "cwd": "packages/cloud-agent-client"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run --passWithNoTests",
        "cwd": "packages/cloud-agent-client"
      }
    }
  },
  "tags": ["scope:adapter", "type:library"]
}
