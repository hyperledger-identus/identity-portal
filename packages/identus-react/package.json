{
  "name": "@hyperledger/identus-react",
  "version": "0.0.0",
  "description": "Identus SDK - React hooks and wrappers",
  "type": "module",
  "main": "./build/index.cjs",
  "module": "./build/index.js",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "import": "./build/index.js",
      "require": "./build/index.cjs",
      "default": "./build/index.js"
    },
    "./hooks": {
      "types": "./build/hooks/index.d.ts",
      "import": "./build/hooks/index.js",
      "default": "./build/hooks/index.js"
    },
    "./provider": {
      "types": "./build/provider/index.d.ts",
      "import": "./build/provider/index.js",
      "default": "./build/provider/index.js"
    },
    "./context": {
      "types": "./build/context/index.d.ts",
      "import": "./build/context/index.js",
      "default": "./build/context/index.js"
    }
  },
  "types": "./build/index.d.ts",
  "files": [
    "build/**/*",
    "README.md"
  ],
  "browserslist": [
    "last 2 chrome version",
    "last 2 firefox version",
    "last 2 safari version",
    "last 2 edge version"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts --format esm,cjs && tsup --config tsup.types.config.ts --dts-only",
    "lint": "eslint .",
    "test": "vitest --config=vitest.config.js --run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "author": "IOHK",
  "repository": {
    "type": "git",
    "url": "https://github.com/hyperledger-identus/identity-portal.git",
    "directory": "packages/identus-react"
  },
  "license": "Apache-2.0",
  "keywords": [],
  "dependencies": {
    "@stablelib/uuid": "^1.0.2",
    "multiformats": "^13.4.2",
    "uuid": "^11.1.0"
  },
  "peerDependencies": {
    "@hyperledger/identus-sdk": "^8.0.0",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@hyperledger/identus-sdk": "^8.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^18.3.25",
    "@types/react-dom": "^18.3.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
